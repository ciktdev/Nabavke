<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <title>Fondovi - Nabavke</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <h2>Upravljanje Nabavkama</h2>

    <div class="forma">
        <h3>Dodaj novi izvor finansiranja ručno</h3>
        <form action="/dodaj" method="POST">
            <input type="text" name="ime" placeholder="Izvor finansiranja" required>
            <input type="number" name="sredstva" placeholder="Iznos" required>
            <input type="number" name="godina" value="<%= new Date().getFullYear() %>" placeholder="Godina" required>
            <button type="submit">Dodaj fond</button>
        </form>
    </div>

    <div class="forma excel-sekcija">
        <h3>Uvoz podataka iz Excel-a</h3>
    
        <div style="margin-bottom: 20px; padding: 10px; border-bottom: 1px dashed #999;">
            <label><strong>1. Odaberi specifične fajlove:</strong></label><br>
            <p><small>Možeš izabrati jedan ili više fajlova (drži Ctrl za više).</small></p>
            <input type="file" id="fileInput" multiple accept=".xlsx, .xls">
            <button type="button" onclick="posaljiSaInputa('fileInput')">Učitaj izabrane fajlove</button>
        </div>

        <div style="padding: 10px;">
            <label><strong>2. Odaberi ceo folder:</strong></label><br>
            <p><small>Skeniranje svih Excel fajlova unutar izabranog foldera.</small></p>
            <input type="file" id="folderInput" webkitdirectory directory multiple>
            <button type="button" onclick="posaljiSaInputa('folderInput')">Skeniraj ceo folder</button>
        </div>
    </div>

    <div class="filter-kolona-kontejner" style="background: #f4f4f4; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #ddd;">
        <h5 style="margin-top: 0;">Podesi prikaz kolona:</h5>
        <div style="display: flex; flex-wrap: wrap; gap: 15px;">
            <label><input type="checkbox" class="col-toggle" value="col-datum" checked> Datum nabavke</label>
            <label><input type="checkbox" class="col-toggle" value="col-racun" checked> Br. računa</label>
            <label><input type="checkbox" class="col-toggle" value="col-artikal" checked> Naziv artikla</label>
            <label><input type="checkbox" class="col-toggle" value="col-kolicina"> Količina</label>
            <label><input type="checkbox" class="col-toggle" value="col-cena-bez"> Cena bez PDV</label>
            <label><input type="checkbox" class="col-toggle" value="col-cena-sa"> Cena sa PDV</label>
            <label><input type="checkbox" class="col-toggle" value="col-vred-bez"> Vrednost bez PDV</label>
            <label><input type="checkbox" class="col-toggle" value="col-vred-sa" checked> Vrednost sa PDV</label>
            <label><input type="checkbox" class="col-toggle" value="col-status"> Status plaćanja</label>
            <label><input type="checkbox" class="col-toggle" value="col-datum-pl"> Datum plaćanja</label>
            <label><input type="checkbox" class="col-toggle" value="col-institut" checked> Institut</label>
        </div>
        <button onclick="primeniPrikazKolona()" style="margin-top: 15px; padding: 8px 20px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
            Primeni promene
        </button>
    </div>

    <fieldset class="forma">
        <legend>Filteri i Pretraga</legend>
        <form action="/" method="GET">
            <input type="text" name="pretraga" placeholder="Pretraži po imenu..." value="<%= filteri.pretraga || '' %>">
            
            <input type="number" name="godina" placeholder="Godina" value="<%= filteri.godina || '' %>" style="width: 80px;">

            <button type="submit">Filtriraj</button>
            <a href="/" style="margin-left: 10px; text-decoration: none; color: #666;">Poništi</a>
        </form>
    </fieldset>

    <table>
        <thead>
            <tr>
                <th>
                    <a href="/?godina=<%= filteri.godina %>&pretraga=<%= filteri.pretraga %>&sort_by=godina&order=<%= (filteri.sort_by === 'godina' && filteri.order === 'asc') ? 'desc' : 'asc' %>">
                        Godina <%= filteri.sort_by === 'godina' ? (filteri.order === 'asc' ? '🔼' : '🔽') : '' %>
                    </a>
                </th>
                <th>
                    <a href="/?godina=<%= filteri.godina %>&pretraga=<%= filteri.pretraga %>&sort_by=ime&order=<%= (filteri.sort_by === '' && filteri.order === 'asc') ? 'desc' : 'asc' %>">
                        Ime fonda <%= filteri.sort_by === 'ime' ? (filteri.order === 'asc' ? '🔼' : '🔽') : '' %>
                    </a>
                </th>
                <th>
                    <a href="/?godina=<%= filteri.godina %>&pretraga=<%= filteri.pretraga %>&sort_by=sredstva&order=<%= (filteri.sort_by === 'sredstva' && filteri.order === 'asc') ? 'desc' : 'asc' %>">
                        Sredstva (Planirano) <%= filteri.sort_by === 'sredstva' ? (filteri.order === 'asc' ? '🔼' : '🔽') : '' %>
                    </a>
                </th>
                
                <th>Utrošeno (Suma kontova)</th>
                <th>Dostupno</th>
                
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
        <% fondovi.forEach(fond => { %>
            <tr class="fond-glavni-red" style="cursor: pointer;" onclick="prikaziKonta('<%= fond.id %>')">
                <td><strong><%= fond.godina %></strong> </td>
                <td><strong><%= fond.ime %></strong> </td>
                
                <td class="sredstva-celija" onclick="event.stopPropagation(); izmeniSredstva('<%= fond.id %>', '<%= fond.ime %>', '<%= fond.sredstva %>')">
                    <span id="iznos-<%= fond.id %>">
                        <%= Number(fond.sredstva).toLocaleString('sr-RS', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                    </span> 
                </td>
                
                <td style="color: #d9534f;">
                    <%= Number(fond.utrosena_sredstva).toLocaleString('sr-RS', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </td>
                
                <td style="font-weight: bold; color: <%= fond.dostupna_sredstva < 0 ? 'red' : 'green' %>">
                   <%= Number(fond.dostupna_sredstva).toLocaleString('sr-RS', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </td>
                
                <td>
                    <button class="btn-obrisi" onclick="event.stopPropagation(); potvrdiBrisanje('<%= fond.id %>', '<%= fond.ime %>')">
                        🗑️
                    </button> 
                </td>
            </tr>

            <tr id="fond-expand-<%= fond.id %>" class="fond-expand-red" style="display: none;">
                <td colspan="6">
                    <div id="lista-konta-<%= fond.id %>" style="padding: 15px; border: 1px solid #adc5cf; border-radius: 8px; margin: 10px; background: #fff;">
                        <p>Učitavanje kontova...</p> 
                    </div>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>

    <script src="/js/script.js"></script> 
</body>
</html>