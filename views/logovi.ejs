<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistemski Logovi</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f6f9; margin: 20px; color: #333; }
        h1 { color: #2c3e50; }
        .nav-link { background: #007bff; color: white; text-decoration: none; padding: 10px 15px; border-radius: 4px; display: inline-block; margin-bottom: 20px; }
        .tabs { display: flex; gap: 10px; margin-bottom: 15px; }
        .tab-btn { padding: 10px 20px; border: none; background: #ddd; cursor: pointer; border-radius: 4px; font-weight: bold; }
        .tab-btn.active { background: #2c3e50; color: white; }
        .log-kontejner { display: none; background: #1e1e1e; color: #39ff14; padding: 15px; border-radius: 6px; box-shadow: inset 0 0 10px #000; overflow-y: auto; max-height: 600px; white-space: pre-wrap; font-family: 'Courier New', Courier, monospace; font-size: 14px; }
        .log-kontejner.active { display: block; }
        .err-log { color: #ff4a4a; }
        .promene-log { color: #00ffff; }
    </style>
</head>
<body>

    <a href="/" class="nav-link">← Nazad na Početnu</a>
    <h1>Sistemski Pregled Logova Uživo</h1>

    <div class="tabs">
        <button class="tab-btn active" onclick="otvoriTab(event, 'tab-konzola')">Trenutno Skeniranje</button>
        <button class="tab-btn" onclick="otvoriTab(event, 'tab-greske')">Greške sa Skeniranja</button>
        <button class="tab-btn" onclick="otvoriTab(event, 'tab-promene')">Istorija Promena (Stari Log)</button>
    </div>

    <div id="tab-konzola" class="log-kontejner active"><%= konzola %></div>

    <div id="tab-greske" class="log-kontejner err-log"><%= greske %></div>

    <div id="tab-promene" class="log-kontejner promene-log"><%= promene %></div>

    <script>
        function otvoriTab(evt, tabName) {
            // Sakrij sve logove
            document.querySelectorAll('.log-kontejner').forEach(el => el.classList.remove('active'));
            // Skloni aktivnu klasu sa dugmića
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            
            // Prikaži trenutni tab i proglasi dugme aktivnim
            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');

            // Automatski skroluj na dno loga da se odmah vidi najnoviji zapis
            const aktivniLog = document.getElementById(tabName);
            aktivniLog.scrollTop = aktivniLog.scrollHeight;
        }

        // Automatski skroluj prvi tab na dno pri učitavanju
        window.onload = function() {
            const kon = document.getElementById('tab-konzola');
            kon.scrollTop = kon.scrollHeight;
        };
    </script>
</body>
</html>